    "from sklearn.svm import SVC\n",
    "from sklearn.datasets import make_classification\n",
    "\n",
    "# Generate a linearly separable dataset\n",
    "X, Y = make_classification(n_features=2, n_redundant=0, n_informative=2, random_state=6, n_clusters_per_class=1)\n",
    "\n",
    "\n",
    "# Fit SVM with linear kernel\n",
    "svm_linear = SVC(kernel='linear', C=100).fit(X, Y) \n",
    "\n",
    "# Set plot size (width, height) in inches\n",
    "plt.figure(figsize=(6, 4))\n",
    "\n",
    "# Plot the data and the decision function\n",
    "plt.scatter(X[:, 0], X[:, 1], c=Y, cmap=plt.cm.coolwarm, edgecolors='k')\n",
    "plt.title('Linear Kernel SVM')\n",
    "plt.xlabel('Feature 1')\n",
    "plt.ylabel('Feature 2')\n",
    "\n",
    "# Plot decision boundary and margins\n",
    "ax = plt.gca()\n",
    "xlim = ax.get_xlim()\n",
    "ylim = ax.get_ylim()\n",
    "\n",
    "# Create grid to plot decision boundary and margins\n",
    "xx = np.linspace(xlim[0], xlim[1], 30)\n",
    "yy = np.linspace(ylim[0], ylim[1], 30)\n",
    "YY, XX = np.meshgrid(yy, xx)\n",
    "xy = np.vstack([XX.ravel(), YY.ravel()]).T\n",
    "Z = svm_linear.decision_function(xy).reshape(XX.shape)\n",
    "\n",
    "# Plot decision boundary and margins\n",
    "ax.contour(XX, YY, Z, colors='k', levels=[-1, 0, 1], alpha=0.5, linestyles=['--', '-', '--'])\n",
    "\n",
    "# Highlight support vectors with a circle around them\n",
    "ax.scatter(svm_linear.support_vectors_[:, 0], svm_linear.support_vectors_[:, 1], \n",
    "           s=100, linewidth=1, facecolors='none', edgecolors='k')\n",
    "\n",
    "plt.show()"
   ]
