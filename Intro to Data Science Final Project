    "from sklearn.cluster import KMeans\n",
    "from sklearn.metrics import silhouette_score\n",
    "from sklearn.decomposition import PCA\n",
    "\n",
    "# dimensionality reduction without 'diagnosis' column\n",
    "pca = PCA(n_components = 4)\n",
    "reduced_dataset = pca.fit_transform(df)\n",
    "\n",
    "kmeans = KMeans(n_clusters=4, random_state=0)\n",
    "sklearn_labels = kmeans.fit_predict(reduced_dataset)\n",
    "\n",
    "# Using silhouette to find the optimal number of clusters\n",
    "sil = []\n",
    "max = 7\n",
    "\n",
    "# dissimilarity would not be defined for a single cluster, thus, minimum number of clusters should be 2\n",
    "for k in range(2, max+1):\n",
    "  kmeans = KMeans(n_clusters = k).fit(reduced_dataset)\n",
    "  labels = kmeans.labels_\n",
    "  scores = sil.append(silhouette_score(reduced_dataset, labels, metric = 'euclidean'))\n",
    "\n",
    "plt.plot(range(2, max+1), sil, marker='o')\n",
    "plt.title('Optimal K-means Clustering')\n",
    "plt.xlabel('Number of Clusters (k)')\n",
    "plt.ylabel('Silhouette Score')\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "kmeans_acc = silhouette_score(reduced_dataset,sklearn_labels)\n",
    "print(f\"Silhouette score for optimal k value: {kmeans_acc*100:.2f}%\")"
   ]
